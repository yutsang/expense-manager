# Copy to .env and fill in values.
# NEVER commit .env to git.

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_64_char_random_hex_string_here_00000000000000000
ENVIRONMENT=development
DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_pw@localhost:5432/aegis_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── S3 / MinIO (local dev) ───────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=aegis-documents
S3_BUCKET_EXPORTS=aegis-exports
S3_REGION=us-east-1

# ─── Email (Mailhog dev) ──────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@aegis.local
SMTP_TLS=false

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
