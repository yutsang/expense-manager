{
  "framework": "nextjs",
  "buildCommand": "cd ../../ && npm i -g pnpm@9.15.9 && pnpm --filter @aegis/web build",
  "installCommand": "cd ../../ && npm i -g pnpm@9.15.9 && pnpm install --no-frozen-lockfile",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://aegis-erp-api-551455410644.asia-southeast1.run.app/v1/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://aegis-erp-api-551455410644.asia-southeast1.run.app"
  }
}
